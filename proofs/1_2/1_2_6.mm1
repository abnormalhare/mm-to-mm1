import "1_2_5.mm1";

-- 1.2.6 - Logical conjunction --

def wa(p s: wff): wff = $ ~(p -> ~s) $;
infixl wa: $^$ prec 76;
theorem df_an(p s: wff): $ p ^ s <-> ~(p -> ~s) $ = 'biid;

theorem pm4_63(p s: wff): $ ~(p -> ~s) <-> p ^ s $ = '(bicomi df_an);

theorem pm4_67(p s: wff): $ ~(~p -> ~s) <-> ~p ^ s $ = 'pm4_63;

theorem imnan(p s: wff): $ p -> ~s <-> ~(p ^ s) $ = '(con2bii df_an);

theorem imnani(p s: wff) (imnani_1: $ ~(p ^ s) $): $ p -> ~s $
    = '(mpbir imnani_1 imnan);

theorem iman(p s: wff): $ p -> s <-> ~(p ^ ~s) $
    = '(bitri (imbi2i notnotb) imnan);

theorem pm3_24(p: wff): $ ~(p ^ ~p) $
    = '(mpbi id iman);

theorem annim(p s: wff): $ p ^ ~s <-> ~(p -> s) $
    = '(con2bii iman);

theorem pm4_61(p s: wff): $ ~(p -> s) <-> p ^ ~s $
    = '(bicomi annim);

theorem pm4_65(p s: wff): $ ~(~p -> s) <-> ~p ^ ~s $ = 'pm4_61;

theorem imp(p s c: wff) (imp_1: $ p -> s -> c $): $ (p ^ s) -> c $
    = '(sylbi df_an (impi imp_1));

theorem impcom(p s c: wff) (imp_1: $ p -> s -> c $): $ (s ^ p) -> c $
