theorem con3dimp(p s c: wff) (con3dimp_1: $ p -> s -> c $): $ (p ^ ~c) -> ~s $
    = '(imp (con3d con3dimp_1));

theorem mpnanrd(p s c: wff) (mpnanrd_1: $ p -> s $) (mpnanrd_2: $ p -> ~(s ^ c) $): $ p -> ~c $
    = '(mpd mpnanrd_1 (sylibr mpnanrd_2 imnan));

