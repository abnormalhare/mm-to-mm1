theorem pm11_53v{x: setvar} {y: setvar} (p: wff x) (s: wff y): $ A{x A{y p -> s}} <-> (E{x p} -> A{y s}) $
    = '(bitri (albii _19_21v) _19_23v);

theorem _19_36imv{x: setvar} (p: wff x) (s: wff): $ E{x p -> s} -> (A{x p} -> s) $
    = '(syl6com (aleximi pm2_27) ax5e);

theorem _19_36iv{x: setvar} (p: wff x) (s: wff) (_19_36iv_1: $ E{x p -> s} $): $ A{x p} -> s $
    = '(ax_mp _19_36iv_1 _19_36imv);

theorem _19_37imv{x: setvar} (p: wff) (s: wff x): $ E{x p -> s} -> (p -> E{x s}) $
    = '(syl5 ax_5 (biimpi _19_35));

theorem _19_37iv{x: setvar} (p: wff) (s: wff x) (_19_37iv_1: $ E{x p -> s} $): $ p -> E{x s} $
    = '(ax_mp _19_37iv_1 _19_37imv);

theorem _19_41v{x: setvar} (p: wff x) (s: wff): $ E{x p ^ s} <-> (E{x p} ^ s) $
    = '(impbii (syl _19_40 (anim2i ax5e)) (impcom (eximdv pm3_21)));

theorem _19_41vv{x y: setvar} (p: wff x y) (s: wff): $ E{x E{y p ^ s}} <-> (E{x E{y p}} ^ s) $
    = '(bitri (exbii _19_41v) _19_41v);

theorem _19_41vvv{x y z: setvar} (p: wff x y z) (s: wff): $ E{x E{y E{z p ^ s}}} <-> (E{x E{y E{z p}}} ^ s) $
    = '(bitri (exbii _19_41vv) _19_41v);

theorem _19_41vvvv{x y z w: setvar} (p: wff x y z w) (s: wff): $ E{w E{x E{y E{z p ^ s}}}} <-> (E{w E{x E{y E{z p}}}} ^ s) $
