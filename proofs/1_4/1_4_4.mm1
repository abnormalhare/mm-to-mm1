import "1_4_3.mm1";

-- 1_4_4 - Axiom scheme ax-5 (Distinctness) --

axiom ax_5{x: setvar} (p: wff): $ p -> A{x p} $;

theorem ax5d{x: setvar} (p: wff x) (s: wff): $ p -> s -> A{x s} $
    = '(a1i ax_5);

theorem ax5e{x: setvar} (p: wff): $ E{x p} -> p $
    = '(mpbir ax_5 eximal);

theorem ax5ea{x: setvar} (p: wff): $ E{x p} -> A{x p} $
    = '(syl ax5e ax_5);

theorem nfv{x: setvar} (p: wff): $ F{x p} $
    = '(nfi ax5ea);

theorem nfvd{x: setvar} (p: wff x) (s: wff): $ p -> F{x s} $
    = '(a1i nfv);

theorem alimdv{x: setvar} (p: wff) (s c: wff x) (alimdv_1: $ p -> s -> c $): $ p -> (A{x s} -> A{x c}) $
    = '(alimdh ax_5 alimdv_1);

theorem eximdv{x: setvar} (p: wff) (s c: wff x) (alimdv_1: $ p -> s -> c $): $ p -> (E{x s} -> E{x c}) $
    = '(eximdh ax_5 alimdv_1);

theorem _2alimdv{x: setvar} (p: wff) (s c: wff x y) (_2alimdv_1: $ p -> s -> c $): $ p -> (A{x A{y s}} -> A{x A{y c}}) $
    = '(alimdv (alimdv _2alimdv_1));

theorem _2eximdv{x: setvar} (p: wff) (s c: wff x y) (_2alimdv_1: $ p -> s -> c $): $ p -> (E{x E{y s}} -> E{x E{y c}}) $
    = '(eximdv (eximdv _2alimdv_1));

theorem albidv{x: setvar} (p: wff) (s c: wff x) (albidv_1: $ p -> (s <-> c) $): $ p -> (A{x s} <-> A{x c}) $
    = '(albidh ax_5 albidv_1);

theorem exbidv{x: setvar} (p: wff) (s c: wff x) (albidv_1: $ p -> (s <-> c) $): $ p -> (E{x s} <-> E{x c}) $
    = '(exbidh ax_5 albidv_1);

theorem nfbidv{x: setvar} (p: wff) (s c: wff x) (albidv_1: $ p -> (s <-> c) $): $ p -> (F{x s} <-> F{x c}) $
    = '(_3bitr4g (imbi12d (exbidv albidv_1) (albidv albidv_1)) df_nf df_nf);

theorem _2albidv{x y: setvar} (p: wff) (s c: wff x y) (_2albidv_1: $ p -> (s <-> c) $): $ p -> (A{x A{y s}} <-> A{x A{y c}}) $
    = '(albidv (albidv _2albidv_1));

theorem _2exbidv{x y: setvar} (p: wff) (s c: wff x y) (_2albidv_1: $ p -> (s <-> c) $): $ p -> (E{x E{y s}} <-> E{x E{y c}}) $
    = '(exbidv (exbidv _2albidv_1));

theorem _3exbidv{x y z: setvar} (p: wff) (s c: wff x y z) (_3exbidv_1: $ p -> (s <-> c) $): $ p -> (E{x E{y E{z s}}} <-> E{x E{y E{z c}}}) $
    = '(_2exbidv (exbidv _3exbidv_1));

theorem _4exbidv{x y z w: setvar} (p: wff) (s c: wff x y z w) (_4exbidv_1: $ p -> (s <-> c) $): $ p -> (E{x E{y E{z E{w s}}}} <-> E{x E{y E{z E{w c}}}}) $
    = '(_2exbidv (_2exbidv _4exbidv_1));

theorem alrimiv{x: setvar} (p: wff) (s: wff x) (alrimiv_1: $ p -> s $): $ p -> A{x s} $
    = '(alrimih ax_5 alrimiv_1);

theorem alrimivv{x y: setvar} (p: wff) (s: wff x y) (alrimivv_1: $ p -> s $): $ p -> A{x A{y s}} $
    = '(alrimiv (alrimiv alrimivv_1));

theorem alrimdv{x: setvar} (p s: wff) (c: wff x) (alrimdv_1: $ p -> s -> c $): $ p -> s -> A{x c} $
    = '(alrimdh ax_5 ax_5 alrimdv_1);

theorem exlimiv{x: setvar} (p: wff x) (s: wff) (exlimiv_1: $ p -> s $): $ E{x p} -> s $
    = '(syl (eximi exlimiv_1) ax5e);

theorem exlimiiv{x: setvar} (p: wff x) (s: wff) (exlimiv_1: $ p -> s $) (exlimiiv_2: $ E{x p} $): $ s $
    = '(ax_mp exlimiiv_2 (exlimiv exlimiv_1));

theorem exlimivv{x y: setvar} (p: wff x y) (s: wff) (exlimivv_1: $ p -> s $): $ E{x E{y p}} -> s $
    = '(exlimiv (exlimiv exlimivv_1));

theorem exlimdv{x: setvar} (s: wff x) (p c: wff) (exlimdv_1: $ p -> s -> c $): $ p -> E{x s} -> c $
    = '(syl6 (eximdv exlimdv_1) ax5e);

theorem exlimdvv{x y: setvar} (s: wff x y) (p c: wff) (exlimdvv_1: $ p -> s -> c $): $ p -> E{x E{y s}} -> c $
    = '(exlimdv (exlimdv exlimdvv_1));

theorem exlimddv{x: setvar} (s: wff x) (p c: wff) (exlimddv_1: $ p -> E{x s} $) (exlimddv_2: $ (p ^ s) -> c $): $ p -> c $
    = '(mpd exlimddv_1 (exlimdv (ex exlimddv_2)));

theorem nexdv{x: setvar} (p: wff) (s: wff x) (nexdv_1: $ p -> ~s $): $ p -> ~E{x s} $
    = '(nexdh ax_5 nexdv_1);

theorem _2ax5{x y: setvar} (p: wff): $ p -> A{x A{y p}} $
    = '(alrimivv id);

theorem stdpc5v{x: setvar} (p: wff) (s: wff x): $ A{x p -> s} -> (p -> A{x s}) $
    = '(syl5 ax_5 alim);

theorem _19_21v{x: setvar} (p: wff) (s: wff x): $ A{x p -> s} <-> (p -> A{x s}) $
