import "1_4_2.mm1";

-- 1_4_3 - Axiom scheme ax-4 (Quantified Implication) --

axiom ax_4{x: setvar} (p s: wff x): $ A{x p -> s} -> A{x p} -> A{x s} $;

theorem alim{x: setvar} (p s: wff x): $ A{x p -> s} -> A{x p} -> A{x s} $ = 'ax_4;

theorem alimi{x: setvar} (p s: wff x) (alimi_1: $ p -> s $): $ A{x p} -> A{x s} $
    = '(mpg alim alimi_1);

theorem _2alimi{x y: setvar} (p s: wff x y) (alimi_1: $ p -> s $): $ A{x A{y p}} -> A{x A{y s}} $
    = '(alimi (alimi alimi_1));

theorem ala1{x: setvar} (p s: wff x): $ A{x p} -> A{x s -> p} $
    = '(alimi ax_1);

theorem al2im{x: setvar} (p s c: wff x): $ A{x p -> s -> c} -> (A{x p} -> A{x s} -> A{x c}) $
    = '(syl6 alim alim);

theorem al2imi{x: setvar} (p s c: wff x) (al2imi_1: $ p -> s -> c $): $ A{x p} -> A{x s} -> A{x c} $
    = '(mpg al2im al2imi_1);

