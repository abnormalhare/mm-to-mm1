    = '(imp (al2imi (ex alanimi_1)));

theorem alimdh{x: setvar} (p s c: wff x) (alimdh_1: $ p -> A{x p} $) (alimdh_2: $ p -> s -> c $): $ p -> A{x s} -> A{x c} $
    = '(syl alimdh_1 (al2imi alimdh_2));

theorem albi{x: setvar} (p s: wff x): $ A{x p <-> s} -> (A{x p} <-> A{x s}) $
    = '(impbid (al2imi biimp) (al2imi biimpr));

theorem albii{x: setvar} (p s: wff x) (albii_1: $ p <-> s $): $ A{x p} <-> A{x s} $
    = '(mpg albi albii_1);

theorem _2albii{x y: setvar} (p s: wff x y) (albii_1: $ p <-> s $): $ A{x A{y p}} <-> A{x A{y s}} $
    = '(albii (albii albii_1));

theorem _3albii{x y z: setvar} (p s: wff x y z) (albii_1: $ p <-> s $): $ A{x A{y A{z p}}} <-> A{x A{y A{z s}}} $
    = '(albii (_2albii albii_1));

theorem sylgt{x: setvar} (p s c: wff x): $ A{x s -> c} -> (p -> A{x s}) -> (p -> A{x c}) $
    = '(imim2d alim);

theorem sylg{x: setvar} (p s c: wff x) (sylg_1: $ p -> A{x s} $) (sylg_2: $ s -> c $): $ p -> A{x c}$
    = '(syl sylg_1 (alimi sylg_2));

theorem alrimih{x: setvar} (p s: wff x) (alrimih_1: $ p -> A{x p} $) (alrimih_2: $ p -> s $): $ p -> A{x s} $
    = '(sylg alrimih_1 alrimih_2);

theorem hbxfrbi{x: setvar} (p s: wff x) (hbxfrbi_1: $ p <-> s $) (hbxfrbi_2: $ s -> A{x s} $): $ p -> A{x p} $
    = '(_3imtr4i hbxfrbi_2 hbxfrbi_1 (albii hbxfrbi_1));

theorem alex{x: setvar} (p: wff x): $ A{x p} <-> ~E{x ~p} $
    = '(bitri (albii notnotb) alnex);

theorem exnal{x: setvar} (p: wff x): $ E{x ~p} <-> ~A{x p} $
